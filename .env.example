# Copy to .env and fill in. NEVER commit a real token.

# Mapbox public token (pk.*) — used at runtime to load map styles/tiles.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-public-mapbox-token

# Mapbox secret download token (sk.* with DOWNLOADS:READ scope) — used by the
# @rnmapbox/maps config plugin during the native (EAS) build only.
RNMAPBOX_DOWNLOAD_TOKEN=sk.your-secret-download-token
