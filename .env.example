# Copy to .env and fill in. NEVER commit a real token.

# Mapbox public token (pk.*) — used at runtime to load map styles/tiles.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-public-mapbox-token

# Mapbox secret download token (sk.* with DOWNLOADS:READ scope) — used by the
# @rnmapbox/maps config plugin during the native (EAS) build only.
RNMAPBOX_DOWNLOAD_TOKEN=sk.your-secret-download-token

# Gemini API key (Google AI Studio) — powers the "Saan tayo lilikas?" ReAct
# agent. DEMO-ONLY direct-from-app usage; set a budget cap on the key. Must move
# behind the gemini-proxy Edge Function before any public release (design §4).
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Supabase — the app reads live DRRM hazard reports filed via the web dashboard.
# Optional: if unset, the app falls back to bundled seed hazards (offline demo).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
