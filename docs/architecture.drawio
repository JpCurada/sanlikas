<mxfile host="app.diagrams.net" type="device">
  <diagram name="SanLikas Architecture" id="sanlikas-arch">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="SanLikas: ReAct Agent + A* Search Architecture" style="text;html=1;fontSize=26;fontStyle=1;fontColor=#000000;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="44" as="geometry" />
        </mxCell>

        <!-- ===== LEFT: USERS ===== -->
        <mxCell id="resident" value="Resident" style="shape=umlActor;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;fontSize=14;fontStyle=1;verticalLabelPosition=bottom;verticalAlign=top;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="50" height="90" as="geometry" />
        </mxCell>
        <mxCell id="authority" value="DRRM Authority" style="shape=umlActor;html=1;strokeColor=#000000;fillColor=#ffffff;fontColor=#000000;fontSize=14;fontStyle=1;verticalLabelPosition=bottom;verticalAlign=top;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="75" y="720" width="50" height="90" as="geometry" />
        </mxCell>
        <mxCell id="web" value="Web Dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=15;fontStyle=1;arcSize=20;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="725" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- ===== INPUT / OUTPUT (ReAct ends) ===== -->
        <mxCell id="input" value="Input&#10;&quot;Saan tayo lilikas?&quot;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=14;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="150" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="output" value="Output&#10;Safest route on map" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=14;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="520" width="190" height="80" as="geometry" />
        </mxCell>

        <!-- ===== CENTER: ReAct LOOP ===== -->
        <mxCell id="agent" value="ReAct Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=18;fontStyle=1;arcSize=18;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="320" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="tools" value="Tool Execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=15;fontStyle=1;verticalAlign=top;spacingTop=10;arcSize=12;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="270" width="260" height="220" as="geometry" />
        </mxCell>
        <mxCell id="tool_weather" value="Weather" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=14;arcSize=20;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="905" y="306" width="210" height="44" as="geometry" />
        </mxCell>
        <mxCell id="tool_reports" value="Hazard Reports" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=14;arcSize=20;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="905" y="360" width="210" height="44" as="geometry" />
        </mxCell>
        <mxCell id="tool_route" value="A* Planner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;fontColor=#ffffff;fontSize=14;fontStyle=1;arcSize=20;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="905" y="414" width="210" height="44" as="geometry" />
        </mxCell>

        <!-- ===== RIGHT: DATA SOURCES ===== -->
        <mxCell id="supabase" value="Supabase&#10;(Reports)" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=14;fontStyle=1;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="290" width="120" height="110" as="geometry" />
        </mxCell>
        <mxCell id="graphdata" value="Map + Flood Data&#10;(A* graph)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontSize=13;fontStyle=1;dashed=1;arcSize=14;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="430" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- ================= EDGES ================= -->
        <!-- Resident -> Input -->
        <mxCell id="e_res_in" value="asks" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;fontColor=#000000;fontSize=12;exitX=0.5;exitY=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="resident" target="input">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="105" y="190" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Output -> Resident -->
        <mxCell id="e_out_res" value="route" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;fontColor=#000000;fontSize=12;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="output" target="resident">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="105" y="560" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Input -> Agent -->
        <mxCell id="e_in_agent" value="" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;exitX=1;exitY=0.5;entryX=0;entryY=0.25;" edge="1" parent="1" source="input" target="agent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Agent -> Output -->
        <mxCell id="e_agent_out" value="" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;exitX=0;exitY=0.75;entryX=1;entryY=0.5;" edge="1" parent="1" source="agent" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Agent -> Tools : Action (dashed, top arc) -->
        <mxCell id="e_action" value="Action" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;dashed=1;sketch=1;curved=1;fontColor=#000000;fontSize=15;fontStyle=2;exitX=0.75;exitY=0;entryX=0.25;entryY=0;" edge="1" parent="1" source="agent" target="tools">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="240" />
              <mxPoint x="945" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Tools -> Agent : Observation (solid, bottom arc) -->
        <mxCell id="e_observe" value="Observation" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;fontColor=#000000;fontSize=15;fontStyle=2;exitX=0.25;exitY=1;entryX=0.75;entryY=1;" edge="1" parent="1" source="tools" target="agent">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="945" y="520" />
              <mxPoint x="700" y="520" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Hazard Reports -> Supabase (reads) -->
        <mxCell id="e_reports_sb" value="reads" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;fontColor=#000000;fontSize=12;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tool_reports" target="supabase">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- A* -> Graph data (uses) -->
        <mxCell id="e_route_data" value="uses" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;dashed=1;sketch=1;curved=1;fontColor=#000000;fontSize=12;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tool_route" target="graphdata">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Authority -> Web -->
        <mxCell id="e_auth_web" value="files reports" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;fontColor=#000000;fontSize=12;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="authority" target="web">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Web -> Supabase (writes, bottom path) -->
        <mxCell id="e_web_sb" value="writes" style="endArrow=block;html=1;strokeColor=#000000;strokeWidth=2;sketch=1;curved=1;fontColor=#000000;fontSize=12;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="web" target="supabase">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1300" y="765" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- LEGEND -->
        <mxCell id="legend" value="Dashed: Action / async data         Solid: Observation / runtime flow         A* Planner = core search algorithm" style="text;html=1;fontSize=13;fontColor=#000000;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="870" width="1240" height="24" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
